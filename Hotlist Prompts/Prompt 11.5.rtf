\f2\fs26 \cf0 /**\
 * VIDEO DOWNLOADER\
 *\
 * Given a TikTok or Instagram URL, returns a temporary direct URL\
 * to the video file (or audio-only track if available).\
 *\
 * Supported URL formats:\
 * TikTok:    https://www.tiktok.com/@username/video/1234567890\
 *            https://vm.tiktok.com/shortcode\
 * Instagram: https://www.instagram.com/reel/shortcode\
 *            https://www.instagram.com/p/shortcode\
 *\
 * Function: getVideoDownloadUrl(url: string): Promise<VideoDownloadResult | null>\
 *\
 * Returns:\
 * \{\
 *   audioUrl: string,      // direct URL to audio track (preferred)\
 *   videoUrl: string,      // direct URL to video file (fallback)\
 *   platform: 'tiktok' | 'instagram' | 'youtube' | 'unknown',\
 *   creatorHandle: string | null,\
 *   videoTitle: string | null,\
 *   thumbnailUrl: string | null,\
 *   durationSeconds: number | null\
 * \}\
 *\
 * Returns null if:\
 * - URL is not a supported platform\
 * - Video is private or deleted\
 * - RapidAPI call fails\
 *\
 * Never throws \'97 always return null on failure with a logged error.\
 */\
\pard\pardeftab720\partightenfactor0

\f1\fs24 \cf3 \strokec3 \
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 \strokec2 Step 2 \'97 Audio transcription\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Create 
\f2\fs26 /lib/video/transcription.ts
\f1\fs24 :\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 /**\
 * AUDIO TRANSCRIPTION via OpenAI Whisper API\
 *\
 * Whisper is by far the best transcription model for casual spoken\
 * content \'97 it handles mumbling, background music, fast speech,\
 * and non-standard pronunciation of book titles surprisingly well.\
 *\
 * Cost: ~$0.006 per minute of audio. A 3-minute BookTok video = ~$0.02.\
 *\
 * Add to .env.local:\
 * OPENAI_API_KEY=\
 *\
 * Function: transcribeAudio(audioUrl: string): Promise<TranscriptionResult | null>\
 *\
 * Steps:\
 * 1. Fetch the audio file from audioUrl (stream it, don't load into memory)\
 * 2. Send to OpenAI Whisper API (model: 'whisper-1')\
 * 3. Return:\
 *    \{\
 *      text: string,          // full transcript\
 *      durationSeconds: number,\
 *      language: string       // detected language\
 *    \}\
 *\
 * Add OPENAI_API_KEY to .env.local and .env.example.\
 * Note to user: get key at platform.openai.com \'97 Whisper is very cheap,\
 * $10 of credit will handle thousands of videos.\
 *\
 * Error handling:\
 * - If audio file too large (>25MB Whisper limit): return null with message\
 * - If transcription fails: return null, log error\
 * - Never throw\
 */\
\pard\pardeftab720\partightenfactor0

\f1\fs24 \cf3 \strokec3 \
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 \strokec2 Step 3 \'97 Book extraction with Claude Haiku\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Create 
\f2\fs26 /lib/video/book-extractor.ts
\f1\fs24 :\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 /**\
 * BOOK EXTRACTION\
 *\
 * Takes a video transcript and uses Claude Haiku to extract\
 * structured book recommendations from natural speech.\
 *\
 * Uses claude-haiku-4-5-20251001 (cheap, fast, sufficient for this task)\
 *\
 * Function: extractBooksFromTranscript(\
 *   transcript: string,\
 *   creatorHandle?: string\
 * ): Promise<ExtractedBook[]>\
 *\
 * System prompt to use:\
 * "You are a book recommendation extractor. Given a transcript from a\
 * BookTok or BookStagram video, identify every book that is mentioned,\
 * recommended, reviewed, or discussed. For each book extract:\
 * - title (as clearly as you can determine from context)\
 * - author (if mentioned)\
 * - the creator's sentiment: 'loved' | 'liked' | 'mixed' | 'disliked' | 'neutral'\
 * - a direct quote or close paraphrase of what the creator said about\
 *   this book (max 2 sentences)\
 * - confidence: 'high' (clearly named) | 'medium' (probably this book)\
 *   | 'low' (might be this book)\
 *\
 * Return ONLY a JSON array. No preamble, no explanation.\
 * Example:\
 * [\
 *   \{\
 *     'title': 'A Court of Thorns and Roses',\
 *     'author': 'Sarah J. Maas',\
 *     'sentiment': 'loved',\
 *     'creatorQuote': 'This is the book that got me into romantasy,\
 *                      I have reread it four times.',\
 *     'confidence': 'high'\
 *   \}\
 * ]\
 *\
 * If no books are mentioned, return an empty array [].\
 * Do not include movies, TV shows, or non-book media."\
 *\
 * After getting the array back from Claude:\
 * - Filter out items where confidence === 'low' (too uncertain)\
 * - Return the remaining ExtractedBook array\
 */\
\pard\pardeftab720\partightenfactor0

\f1\fs24 \cf3 \strokec3 \
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 \strokec2 Step 4 \'97 Goodreads resolution\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Create 
\f2\fs26 /lib/video/book-resolver.ts
\f1\fs24 :\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 /**\
 * BOOK RESOLVER\
 *\
 * Takes extracted book mentions and resolves each one to a\
 * canonical Goodreads record in our database.\
 *\
 * Function: resolveExtractedBooks(\
 *   extracted: ExtractedBook[]\
 * ): Promise<ResolvedBook[]>\
 *\
 * For each ExtractedBook:\
 * 1. Search our Supabase cache first (fastest \'97 no external call)\
 *    Query: fuzzy match on title + author\
 * 2. If not in cache: call resolveToGoodreadsId() from our\
 *    Goodreads search module (Prompt 05.7)\
 * 3. If resolved: fetch/create the full book record\
 * 4. If not resolved after both attempts: keep as "unmatched"\
 *    with the original title/author from the transcript\
 *\
 * Return ResolvedBook[]:\
 * \{\
 *   // If matched:\
 *   matched: true,\
 *   book: BookDetail,         // our full canonical book record\
 *   creatorSentiment: string,\
 *   creatorQuote: string,\
 *   confidence: 'high' | 'medium',\
 *\
 *   // If not matched:\
 *   matched: false,\
 *   rawTitle: string,         // what Claude extracted\
 *   rawAuthor: string | null,\
 *   creatorSentiment: string,\
 *   creatorQuote: string,\
 *   confidence: 'high' | 'medium'\
 * \}\
 *\
 * Unmatched books are still shown to the user \'97 they just don't\
 * have ratings/spice data yet. User can manually search for them.\
 */\
\pard\pardeftab720\partightenfactor0

\f1\fs24 \cf3 \strokec3 \
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 \strokec2 Step 5 \'97 Main orchestrator\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Create 
\f2\fs26 /lib/video/index.ts
\f1\fs24 :\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 /**\
 * GRAB FROM VIDEO \'97 Main orchestrator\
 *\
 * This is what the API route calls. Coordinates all the steps.\
 *\
 * Function: grabBooksFromVideo(url: string): Promise<GrabResult>\
 *\
 * Steps (in order, with error handling at each step):\
 * 1. Validate URL format \'97 must be TikTok, Instagram, or YouTube\
 * 2. getVideoDownloadUrl(url) \uc0\u8594  get audio URL\
 *    If fails: return \{ error: 'video_unavailable' \}\
 * 3. transcribeAudio(audioUrl) \uc0\u8594  get transcript\
 *    If fails: return \{ error: 'transcription_failed' \}\
 * 4. extractBooksFromTranscript(transcript) \uc0\u8594  get extracted books\
 *    If empty: return \{ error: 'no_books_found', transcript \}\
 * 5. resolveExtractedBooks(extracted) \uc0\u8594  match to our database\
 * 6. Return GrabResult:\
 *    \{\
 *      success: true,\
 *      platform: 'tiktok' | 'instagram' | 'youtube',\
 *      creatorHandle: string | null,\
 *      thumbnailUrl: string | null,\
 *      booksFound: number,\
 *      books: ResolvedBook[],\
 *      transcript: string,       // raw transcript (shown in expandable section)\
 *      processingTimeMs: number\
 *    \}\
 *\
 * Total cost per video: ~$0.02-0.04 (Whisper + Haiku)\
 * Cache results in Supabase so the same URL is never processed twice.\
 */\
\pard\pardeftab720\sa240\partightenfactor0

\f1\fs24 \cf0 Create the cache table \'97 run in Supabase SQL Editor:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 CREATE TABLE IF NOT EXISTS video_grabs (\
  id              uuid primary key default uuid_generate_v4(),\
  url             text unique not null,\
  platform        text,\
  creator_handle  text,\
  thumbnail_url   text,\
  transcript      text,\
  extracted_books jsonb,   -- the full GrabResult.books array\
  processed_at    timestamptz default now(),\
  user_id         uuid references auth.users(id)  -- who first grabbed it\
);\
\
ALTER TABLE video_grabs ENABLE ROW LEVEL SECURITY;\
CREATE POLICY "Video grabs are public" ON video_grabs FOR SELECT USING (true);\
CREATE POLICY "Authenticated users can create grabs" ON video_grabs\
  FOR INSERT WITH CHECK (auth.uid() = user_id);\
\pard\pardeftab720\partightenfactor0

\f1\fs24 \cf3 \strokec3 \
\pard\pardeftab720\sa298\partightenfactor0

\f0\b\fs36 \cf0 \strokec2 Step 6 \'97 API route\
\pard\pardeftab720\sa240\partightenfactor0

\f1\b0\fs24 \cf0 Create 
\f2\fs26 /app/api/grab/route.ts
\f1\fs24 :\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 /**\
 * POST /api/grab\
 * Body: \{ url: string \}\
 *\
 * 1. Validate URL with zod (must be string, must start with\
 *    tiktok.com, vm.tiktok.com, instagram.com, or youtube.com)\
 * 2. Check video_grabs cache \'97 if this URL was already processed,\
 *    return the cached result immediately (fast + free)\
 * 3. If not cached: call grabBooksFromVideo(url)\
 * 4. Save result to video_grabs cache\
 * 5. Return GrabResult as JSON\
 *\
 * This is a slow endpoint (10-30 seconds for processing).\
 * Use streaming response so the client can show progress.\
 * Stream status updates:\
 * - "downloading" \'97 fetching video\
 * - "transcribing" \'97 running Whisper\
 * - "extracting" \'97 running Claude\
 * - "resolving" \'97 matching to database\
 * - "done" \'97 complete, send final JSON\
 */\
\pard\pardeftab720\partightenfactor0

