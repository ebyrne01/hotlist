# Hotlist — Environment Variables
# Copy this to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=              # console.anthropic.com — Claude Haiku + Sonnet
OPENAI_API_KEY=                 # platform.openai.com — Whisper transcription

# ── Book Data Sources ─────────────────────────────────
GOOGLE_BOOKS_API_KEY=           # console.cloud.google.com → APIs → Books API
NYT_BOOKS_API_KEY=              # developer.nytimes.com — NYT bestseller lists
SERPER_API_KEY=                 # serper.dev — Google search for romance.io + Amazon ratings

# ── Affiliate Links ───────────────────────────────────
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=
AMAZON_AFFILIATE_TAG=
BARNES_NOBLE_AFFILIATE_TAG=
BOOKSHOP_AFFILIATE_TAG=

# ── BookTok Video Pipeline ────────────────────────────
RAPIDAPI_KEY=                   # rapidapi.com — video downloader
RAPIDAPI_VIDEO_HOST=            # specific host for chosen downloader API
RAPIDAPI_TIKTOK_HOST=           # optional — specialized TikTok downloader host

# ── Spotify (Reading Vibes) ───────────────────────────
SPOTIFY_CLIENT_ID=              # developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=          # developer.spotify.com/dashboard

# ── Cron Jobs ─────────────────────────────────────────
CRON_SECRET=                    # shared secret for Vercel cron job auth

# ── Spice System ──────────────────────────────────────
SPICE_LLM_DAILY_LIMIT=100      # optional — max LLM spice inferences per day

# ── Quality Scanner ──────────────────────────────────
QUALITY_SCANNER_DAILY_LIMIT=500 # optional — max Haiku scanner flags per day
