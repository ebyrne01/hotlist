{
  "functions": {
    "app/api/grab/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/enrichment-worker/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-refresh",
      "schedule": "0 10 * * 2"
    },
    {
      "path": "/api/cron/monthly-enrichment",
      "schedule": "0 2 1 * *"
    },
    {
      "path": "/api/cron/seed-lists",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/openlibrary-discovery",
      "schedule": "0 4 * * 3"
    },
    {
      "path": "/api/cron/enrichment-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/spice-backfill",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/refresh-spice",
      "schedule": "0 4 * * *"
    }
  ]
}
